{
  "name": "auto-delivery-server",
  "version": "1.0.0",
  "description": "数字商品自动成交系统后端",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "migrate": "knex migrate:latest",
    "seed": "knex seed:run",
    "reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
  "keywords": ["auto-delivery", "digital-goods", "e-commerce"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.7",
    "knex": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
